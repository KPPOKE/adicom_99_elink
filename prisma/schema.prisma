generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum RoleName {
  admin
  staff
}

enum PaymentMethod {
  Cash
  Transfer
  QRIS
  Ewallet
}

enum ServiceStatus {
  Masuk
  Dicek
  Menunggu_Konfirmasi
  Diproses
  Selesai
  Diambil
  Batal
}

enum FinanceType {
  income
  expense
}

enum DigitalStatus {
  Berhasil
  Pending
  Gagal
}

enum TransactionStatus {
  Berhasil
  Pending
  Batal
}

enum PaymentStatus {
  unpaid
  paid
}

enum BankTransferStatus {
  Pending
  Berhasil
  Gagal
}

model Role {
  id        Int      @id @default(autoincrement())
  name      RoleName @unique
  users     User[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Outlet {
  id                   Int                   @id @default(autoincrement())
  code                 String                @unique
  name                 String
  address              String?               @db.Text
  users                User[]
  transactions         Transaction[]
  services             Service[]
  bankTransfers        BankTransfer[]
  bankTransferDeposits BankTransferDeposit[]
  financeRecords       FinanceRecord[]
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  @@map("outlets")
}

model User {
  id             Int             @id @default(autoincrement())
  name           String
  email          String          @unique
  passwordHash   String          @map("password_hash")
  roleId         Int             @map("role_id")
  role           Role            @relation(fields: [roleId], references: [id])
  outletId       Int?            @map("outlet_id")
  outlet         Outlet?         @relation(fields: [outletId], references: [id])
  transactions   Transaction[]
  services       Service[]
  bankTransfers  BankTransfer[]
  bankTransferDeposits BankTransferDeposit[]
  financeRecords FinanceRecord[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("users")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.Text
  items       Item[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  address   String?  @db.Text
  note      String?  @db.Text
  items     Item[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@map("suppliers")
}

model Customer {
  id           Int           @id @default(autoincrement())
  name         String
  phone        String?
  email        String?
  address      String?       @db.Text
  transactions Transaction[]
  services     Service[]
  bankTransfers BankTransfer[]
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([name])
  @@index([phone])
  @@map("customers")
}

model Item {
  id               Int               @id @default(autoincrement())
  namaBarang       String            @map("nama_barang")
  kodeBarang       String            @unique @map("kode_barang")
  categoryId       Int               @map("kategori_id")
  category         Category          @relation(fields: [categoryId], references: [id])
  gambar           String?
  hargaModal       Decimal           @db.Decimal(14, 2) @map("harga_modal")
  hargaJual        Decimal           @db.Decimal(14, 2) @map("harga_jual")
  stok             Int               @default(0)
  stokMinimum      Int               @default(1) @map("stok_minimum")
  satuan           String            @default("pcs")
  supplierId       Int?              @map("supplier_id")
  supplier         Supplier?         @relation(fields: [supplierId], references: [id])
  deskripsi        String?           @db.Text
  transactionItems TransactionItem[]
  serviceParts     ServicePart[]
  reservedStock    Int               @default(0) @map("reserved_stock")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([supplierId])
  @@index([stok])
  @@index([createdAt])
  @@map("items")
}

model Transaction {
  id              Int               @id @default(autoincrement())
  kodeTransaksi   String            @unique @map("kode_transaksi")
  tanggal         DateTime          @default(now())
  customerId      Int?              @map("customer_id")
  customer        Customer?         @relation(fields: [customerId], references: [id])
  customerName    String?           @map("customer_name")
  total           Decimal           @db.Decimal(14, 2)
  diskon          Decimal           @default(0) @db.Decimal(14, 2)
  grandTotal      Decimal           @db.Decimal(14, 2) @map("grand_total")
  paymentMethod   PaymentMethod     @map("payment_method")
  paidAmount      Decimal           @default(0) @db.Decimal(14, 2) @map("paid_amount")
  changeAmount    Decimal           @default(0) @db.Decimal(14, 2) @map("change_amount")
  nomorTujuan     String?           @map("nomor_tujuan")
  provider        String?
  jenisProduk     String?           @map("jenis_produk")
  serialNumber    String?           @map("serial_number")
  digitalStatus   DigitalStatus?    @map("digital_status")
  status          TransactionStatus @default(Berhasil)
  userId          Int               @map("user_id")
  user            User              @relation(fields: [userId], references: [id])
  outletId        Int?              @map("outlet_id")
  outlet          Outlet?           @relation(fields: [outletId], references: [id])
  items           TransactionItem[]
  financeRecords  FinanceRecord[]
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([userId])
  @@index([outletId])
  @@index([createdAt])
  @@index([tanggal])
  @@index([status])
  @@index([createdAt, status])
  @@index([customerId, createdAt])
  @@map("transactions")
}

model TransactionItem {
  id            Int         @id @default(autoincrement())
  transactionId Int         @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  itemId        Int         @map("item_id")
  item          Item        @relation(fields: [itemId], references: [id])
  qty           Int
  price         Decimal     @db.Decimal(14, 2)
  subtotal      Decimal     @db.Decimal(14, 2)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@index([transactionId])
  @@index([itemId])
  @@map("transaction_items")
}

model Service {
  id                 Int             @id @default(autoincrement())
  kodeService        String          @unique @map("kode_service")
  customerId         Int?            @map("customer_id")
  customer           Customer?       @relation(fields: [customerId], references: [id])
  customerName       String          @map("customer_name")
  customerPhone      String?         @map("customer_phone")
  deviceType         String          @map("device_type")
  deviceBrand        String?         @map("device_brand")
  deviceModel        String?         @map("device_model")
  problemDescription String          @db.Text @map("problem_description")
  diagnosis          String?         @db.Text
  estimatedCost      Decimal         @default(0) @db.Decimal(14, 2) @map("estimated_cost")
  laborCost          Decimal         @default(0) @db.Decimal(14, 2) @map("labor_cost")
  finalCost          Decimal         @default(0) @db.Decimal(14, 2) @map("final_cost")
  status             ServiceStatus   @default(Masuk)
  paymentStatus      PaymentStatus   @default(unpaid) @map("payment_status")
  paidAt             DateTime?       @map("paid_at")
  technicianNote     String?         @db.Text @map("technician_note")
  receivedDate       DateTime        @default(now()) @map("received_date")
  completedDate      DateTime?       @map("completed_date")
  pickedUpDate       DateTime?       @map("picked_up_date")
  userId             Int             @map("user_id")
  user               User            @relation(fields: [userId], references: [id])
  outletId        Int?              @map("outlet_id")
  outlet          Outlet?           @relation(fields: [outletId], references: [id])
  financeRecords     FinanceRecord[]
  parts              ServicePart[]
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([userId])
  @@index([outletId])
  @@index([createdAt])
  @@index([receivedDate])
  @@index([status])
  @@index([paymentStatus])
  @@index([status, paymentStatus, receivedDate])
  @@map("services")
}

model ServicePart {
  id        Int      @id @default(autoincrement())
  serviceId Int      @map("service_id")
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  itemId    Int      @map("item_id")
  item      Item     @relation(fields: [itemId], references: [id])
  qty       Int
  price     Decimal  @db.Decimal(14, 2)
  subtotal  Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([serviceId, itemId])
  @@index([itemId])
  @@map("service_parts")
}

model BankTransfer {
  id              Int                @id @default(autoincrement())
  kodeTransfer    String             @unique @map("kode_transfer")
  customerId      Int?               @map("customer_id")
  customer        Customer?          @relation(fields: [customerId], references: [id])
  senderName      String?            @map("sender_name")
  senderPhone     String?            @map("sender_phone")
  destinationBank String             @map("destination_bank")
  accountNumber   String             @map("account_number")
  accountName     String             @map("account_name")
  amount          Decimal            @db.Decimal(14, 2)
  adminFee        Decimal            @default(0) @db.Decimal(14, 2) @map("admin_fee")
  totalReceived   Decimal            @db.Decimal(14, 2) @map("total_received")
  status          BankTransferStatus @default(Pending)
  note            String?            @db.Text
  completedAt     DateTime?          @map("completed_at")
  userId          Int                @map("user_id")
  user            User               @relation(fields: [userId], references: [id])
  outletId        Int?              @map("outlet_id")
  outlet          Outlet?           @relation(fields: [outletId], references: [id])
  financeRecord   FinanceRecord?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([userId])
  @@index([outletId])
  @@index([status])
  @@index([createdAt])
  @@index([destinationBank])
  @@map("bank_transfers")
}

model BankTransferDeposit {
  id        Int      @id @default(autoincrement())
  outletId  Int      @map("outlet_id")
  outlet    Outlet   @relation(fields: [outletId], references: [id])
  amount    Decimal  @db.Decimal(14, 2)
  date      DateTime
  note      String?  @db.Text
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([outletId, date])
  @@index([userId])
  @@map("bank_transfer_deposits")
}

model FinanceRecord {
  id            Int          @id @default(autoincrement())
  type          FinanceType
  category      String
  amount        Decimal      @db.Decimal(14, 2)
  description   String?      @db.Text
  date          DateTime     @default(now())
  referenceType String?      @map("reference_type")
  referenceId   Int?         @map("reference_id")
  transactionId Int?         @map("transaction_id")
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  serviceId      Int?          @map("service_id")
  service        Service?      @relation(fields: [serviceId], references: [id])
  bankTransferId Int?          @unique @map("bank_transfer_id")
  bankTransfer   BankTransfer? @relation(fields: [bankTransferId], references: [id])
  userId        Int          @map("user_id")
  user          User         @relation(fields: [userId], references: [id])
  outletId        Int?              @map("outlet_id")
  outlet          Outlet?           @relation(fields: [outletId], references: [id])
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([userId])
  @@index([outletId])
  @@index([transactionId])
  @@index([serviceId])
  @@index([date])
  @@index([type])
  @@index([date, type])
  @@index([category])
  @@map("finance_records")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  userEmail String?  @map("user_email")
  action    String
  entity    String
  entityId  Int?     @map("entity_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Setting {
  id              Int      @id @default(autoincrement())
  storeName       String   @default("PosPintar") @map("store_name")
  logo            String?
  address         String?  @db.Text
  whatsapp        String?
  email           String?
  invoicePrefix   String   @default("INV") @map("invoice_prefix")
  invoiceFooter   String?  @db.Text @map("invoice_footer")
  defaultPrintFormat String @default("thermal_80") @map("default_print_format")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
